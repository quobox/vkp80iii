# Custom VKP80III thermal printer (USB 0dd4:0205)
# Grants the 'lp' group read/write access to the printer's device nodes so a
# normal user (member of 'lp') can print and read status without sudo.
#
# Install:
#   sudo cp 99-vkp80iii.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#
# Then make sure your user is in the 'lp' group:
#   sudo usermod -aG lp "$USER"      # then log out/in, or: sg lp -c '<command>'
#
# Note: TAG+="uaccess" is deliberately NOT used here. systemd-logind does not
# grant uaccess ACLs on the usblp character node (/dev/usb/lp0), so group
# ownership ('lp') is the reliable mechanism on this device.

# usblp character node (/dev/usb/lp0) -- newer kernels: SUBSYSTEM=usbmisc
SUBSYSTEM=="usbmisc", ATTRS{idVendor}=="0dd4", ATTRS{idProduct}=="0205", MODE="0660", GROUP="lp"
# usblp character node -- older kernels expose it under the 'usb' subsystem
KERNEL=="lp[0-9]*", SUBSYSTEMS=="usb", ATTRS{idVendor}=="0dd4", ATTRS{idProduct}=="0205", MODE="0660", GROUP="lp"
# raw USB device node (for the pyusb backend)
SUBSYSTEM=="usb", ATTRS{idVendor}=="0dd4", ATTRS{idProduct}=="0205", MODE="0660", GROUP="lp"
